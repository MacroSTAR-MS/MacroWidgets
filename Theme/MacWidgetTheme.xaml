<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <!-- ======================================================== -->
    <!--  MacWidget Design System — Unified Tokens               -->
    <!--  Inspired by macOS Sequoia + Windows 11 Mica            -->
    <!-- ======================================================== -->

    <!-- ════════════ Colors — Surfaces ════════════ -->

    <!-- 小组件背景（毛玻璃深色） -->
    <SolidColorBrush x:Key="WidgetBackground"        Color="#1C1C2E" Opacity="0.82" />
    <!-- 卡片/设置项背景（小组件内嵌） -->
    <SolidColorBrush x:Key="CardBackground"          Color="#FFFFFF" Opacity="0.05" />
    <SolidColorBrush x:Key="CardBackgroundHover"     Color="#FFFFFF" Opacity="0.08" />
    <SolidColorBrush x:Key="CardBackgroundPressed"   Color="#FFFFFF" Opacity="0.10" />
    <!-- 输入框/可编辑区域 -->
    <SolidColorBrush x:Key="InputBackground"         Color="#FFFFFF" Opacity="0.06" />
    <!-- 分隔线/边框 -->
    <SolidColorBrush x:Key="WidgetBorder"            Color="#FFFFFF" Opacity="0.08" />
    <SolidColorBrush x:Key="SubtleBorder"            Color="#FFFFFF" Opacity="0.05" />

    <!-- ════════════ Colors — Navigation & Chrome ════════════ -->

    <!-- 导航栏背景 -->
    <SolidColorBrush x:Key="NavBackground"            Color="#000000" Opacity="0.04" />
    <SolidColorBrush x:Key="NavItemSelected"         Color="#FFFFFF" Opacity="0.07" />
    <SolidColorBrush x:Key="NavItemHover"             Color="#FFFFFF" Opacity="0.04" />
    <!-- 页面背景（内容区） -->
    <SolidColorBrush x:Key="PageBackground"           Color="#000000" Opacity="0.00" />
    <!-- 值标签背景（设置项右侧的值） -->
    <SolidColorBrush x:Key="ValueChipBackground"       Color="#FFFFFF" Opacity="0.06" />

    <!-- ════════════ Colors — Text ════════════ -->

    <SolidColorBrush x:Key="PrimaryText"              Color="#FFFFFF" />
    <SolidColorBrush x:Key="SecondaryText"            Color="#B3FFFFFF" />
    <SolidColorBrush x:Key="TertiaryText"             Color="#80FFFFFF" />
    <SolidColorBrush x:Key="DisabledText"             Color="#4DFFFFFF" />
    <SolidColorBrush x:Key="PlaceholderText"         Color="#59FFFFFF" />

    <!-- ════════════ Colors — Accent ════════════ -->

    <SolidColorBrush x:Key="AccentBlue"               Color="#0A84FF" />
    <SolidColorBrush x:Key="AccentBlueMuted"          Color="#0A84FF" Opacity="0.15" />
    <SolidColorBrush x:Key="AccentRed"                 Color="#FF453A" />
    <SolidColorBrush x:Key="AccentGreen"               Color="#30D158" />
    <SolidColorBrush x:Key="AccentOrange"             Color="#FF9F0A" />
    <SolidColorBrush x:Key="AccentYellow"             Color="#FFD60A" />
    <SolidColorBrush x:Key="AccentPink"               Color="#FF375F" />
    <SolidColorBrush x:Key="AccentTeal"                Color="#64D2FF" />
    <SolidColorBrush x:Key="AccentPurple"              Color="#BF5AF2" />

    <!-- Activity rings (Apple Watch style) -->
    <SolidColorBrush x:Key="ActivityMove"             Color="#FF2D55" />
    <SolidColorBrush x:Key="ActivityExercise"          Color="#A8FF04" />
    <SolidColorBrush x:Key="ActivityStand"             Color="#00E5FF" />

    <!-- ════════════ Typography ════════════ -->

    <sys:Double x:Key="FontSizeDisplay">48</sys:Double>
    <sys:Double x:Key="FontSizeHeader">24</sys:Double>
    <sys:Double x:Key="FontSizeTitle">16</sys:Double>
    <sys:Double x:Key="FontSizeSubtitle">14</sys:Double>
    <sys:Double x:Key="FontSizeBody">13</sys:Double>
    <sys:Double x:Key="FontSizeCaption">12</sys:Double>
    <sys:Double x:Key="FontSizeSmall">11</sys:Double>
    <sys:Double x:Key="FontSizeMicro">10</sys:Double>

    <!-- ════════════ Corner Radius ════════════ -->

    <CornerRadius x:Key="RadiusLg">20</CornerRadius>    <!-- 小组件外框 -->
    <CornerRadius x:Key="RadiusMd">12</CornerRadius>    <!-- 卡片/设置项 -->
    <CornerRadius x:Key="RadiusSm">8</CornerRadius>     <!-- 按钮/输入框/标签 -->
    <CornerRadius x:Key="RadiusXs">6</CornerRadius>     <!-- 小标签/checkbox -->
    <CornerRadius x:Key="RadiusPill">999</CornerRadius>  <!-- 药丸形 -->

    <!-- 向后兼容别名 -->
    <CornerRadius x:Key="WidgetCornerRadius">20</CornerRadius>
    <CornerRadius x:Key="CardCornerRadius">12</CornerRadius>
    <CornerRadius x:Key="ButtonCornerRadius">8</CornerRadius>
    <CornerRadius x:Key="PillCornerRadius">999</CornerRadius>

    <!-- ════════════ Spacing ════════════ -->

    <sys:Double x:Key="SpacingXs">4</sys:Double>
    <sys:Double x:Key="SpacingSm">8</sys:Double>
    <sys:Double x:Key="SpacingMd">12</sys:Double>
    <sys:Double x:Key="SpacingLg">16</sys:Double>
    <sys:Double x:Key="SpacingXl">20</sys:Double>
    <sys:Double x:Key="SpacingXxl">24</sys:Double>
    <sys:Double x:Key="SpacingXxxl">32</sys:Double>

    <!-- ════════════ Sizes ════════════ -->

    <sys:Double x:Key="NavWidth">240</sys:Double>
    <sys:Double x:Key="NavItemHeight">40</sys:Double>
    <sys:Double x:Key="SettingsItemHeight">52</sys:Double>
    <sys:Double x:Key="TitleBarHeight">32</sys:Double>

</ResourceDictionary>
