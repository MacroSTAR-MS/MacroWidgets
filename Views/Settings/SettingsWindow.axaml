<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:pages="using:MacroWidgets.Views.Settings.Pages"
        x:Class="MacroWidgets.Views.Settings.SettingsWindow"
        Title="MacroWidgets 设置"
        Width="960" Height="640"
        MinWidth="780" MinHeight="500"
        SystemDecorations="Full"
        CanResize="true"
        WindowStartupLocation="CenterScreen">

    <Grid ColumnDefinitions="240,*">

        <!-- ====== 左侧导航栏 ====== -->
        <Border Grid.Column="0"
                Background="{DynamicResource NavBackground}"
                Padding="12,16">

            <StackPanel Spacing="{DynamicResource SpacingXs}">

                <!-- 分类标题 -->
                <TextBlock Text="设置"
                           FontSize="{DynamicResource FontSizeCaption}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TertiaryText}"
                           Margin="16,0,0,12" />

                <!-- 通用 -->
                <Border x:Name="NavGeneral"
                        Background="Transparent"
                        CornerRadius="{DynamicResource RadiusSm}"
                        Padding="16,12"
                        Cursor="Hand"
                        PointerPressed="NavGeneral_PointerPressed"
                        PointerEntered="Nav_PointerEntered"
                        PointerExited="Nav_PointerExited">
                    <StackPanel Orientation="Horizontal" Spacing="{DynamicResource SpacingMd}">
                        <TextBlock Text="&#xE80F;"
                                   FontSize="{DynamicResource FontSizeSubtitle}"
                                   FontFamily="Segoe MDL2 Assets"
                                   Foreground="{DynamicResource AccentBlue}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="通用"
                                   FontSize="{DynamicResource FontSizeBody}"
                                   Foreground="{DynamicResource PrimaryText}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- 外观 -->
                <Border x:Name="NavAppearance"
                        Background="Transparent"
                        CornerRadius="{DynamicResource RadiusSm}"
                        Padding="16,12"
                        Cursor="Hand"
                        PointerPressed="NavAppearance_PointerPressed"
                        PointerEntered="Nav_PointerEntered"
                        PointerExited="Nav_PointerExited">
                    <StackPanel Orientation="Horizontal" Spacing="{DynamicResource SpacingMd}">
                        <TextBlock Text="&#xE771;"
                                   FontSize="{DynamicResource FontSizeSubtitle}"
                                   FontFamily="Segoe MDL2 Assets"
                                   Foreground="{DynamicResource AccentBlue}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="外观"
                                   FontSize="{DynamicResource FontSizeBody}"
                                   Foreground="{DynamicResource PrimaryText}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- 通知 -->
                <Border x:Name="NavNotification"
                        Background="Transparent"
                        CornerRadius="{DynamicResource RadiusSm}"
                        Padding="16,12"
                        Cursor="Hand"
                        PointerPressed="NavNotification_PointerPressed"
                        PointerEntered="Nav_PointerEntered"
                        PointerExited="Nav_PointerExited">
                    <StackPanel Orientation="Horizontal" Spacing="{DynamicResource SpacingMd}">
                        <TextBlock Text="&#xE7E7;"
                                   FontSize="{DynamicResource FontSizeSubtitle}"
                                   FontFamily="Segoe MDL2 Assets"
                                   Foreground="{DynamicResource AccentBlue}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="通知"
                                   FontSize="{DynamicResource FontSizeBody}"
                                   Foreground="{DynamicResource PrimaryText}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- 高级 -->
                <Border x:Name="NavAdvanced"
                        Background="Transparent"
                        CornerRadius="{DynamicResource RadiusSm}"
                        Padding="16,12"
                        Cursor="Hand"
                        PointerPressed="NavAdvanced_PointerPressed"
                        PointerEntered="Nav_PointerEntered"
                        PointerExited="Nav_PointerExited">
                    <StackPanel Orientation="Horizontal" Spacing="{DynamicResource SpacingMd}">
                        <TextBlock Text="&#xE946;"
                                   FontSize="{DynamicResource FontSizeSubtitle}"
                                   FontFamily="Segoe MDL2 Assets"
                                   Foreground="{DynamicResource AccentBlue}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="高级"
                                   FontSize="{DynamicResource FontSizeBody}"
                                   Foreground="{DynamicResource PrimaryText}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- 分隔线 -->
                <Border Height="1"
                        Background="{DynamicResource SubtleBorder}"
                        Margin="16,16" />

                <!-- 版本 -->
                <TextBlock Text="MacroWidgets v1.0.0"
                           FontSize="{DynamicResource FontSizeSmall}"
                           Foreground="{DynamicResource DisabledText}"
                           Margin="16,8" />
            </StackPanel>
        </Border>

        <!-- ====== 右侧内容区 ====== -->
        <Border Grid.Column="1"
                Background="{DynamicResource PageBackground}">
            <ContentControl x:Name="ContentArea" />
        </Border>

    </Grid>
</Window>
