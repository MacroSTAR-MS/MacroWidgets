<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MacWidget.Views.Settings.Pages.GeneralSettingsPage">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,16,24,24"
                    Spacing="{DynamicResource SpacingSm}" MaxWidth="800">

            <TextBlock Text="通用" FontSize="28" FontWeight="Bold"
                       Foreground="{DynamicResource AccentBlue}"
                       Margin="0,0,0,8" />
            <TextBlock Text="基本应用设置" FontSize="{DynamicResource FontSizeBody}"
                       Foreground="{DynamicResource SecondaryText}"
                       Margin="0,0,0,24" />

            <!-- 天气城市 -->
            <Border Background="{DynamicResource CardBackground}"
                    CornerRadius="{DynamicResource RadiusSm}"
                    Padding="20,14"
                    Margin="0,0,0,4">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Left" Spacing="{DynamicResource SpacingXs}"
                                VerticalAlignment="Center">
                        <TextBlock Text="天气城市" FontSize="{DynamicResource FontSizeSubtitle}"
                                   FontWeight="Medium" />
                        <TextBlock Text="设置天气小组件默认显示的城市"
                                   FontSize="{DynamicResource FontSizeCaption}"
                                   Foreground="{DynamicResource SecondaryText}" />
                    </StackPanel>
                    <Border DockPanel.Dock="Right" Background="{DynamicResource ValueChipBackground}"
                            CornerRadius="{DynamicResource RadiusXs}"
                            Padding="14,6"
                            VerticalAlignment="Center">
                        <TextBlock Text="广州" FontSize="{DynamicResource FontSizeBody}"
                                   Foreground="{DynamicResource SecondaryText}" />
                    </Border>
                </DockPanel>
            </Border>

            <!-- 开机自启 -->
            <Border Background="{DynamicResource CardBackground}"
                    CornerRadius="{DynamicResource RadiusSm}"
                    Padding="20,14"
                    Margin="0,0,0,4">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Left" Spacing="{DynamicResource SpacingXs}"
                                VerticalAlignment="Center">
                        <TextBlock Text="开机自启" FontSize="{DynamicResource FontSizeSubtitle}"
                                   FontWeight="Medium" />
                        <TextBlock Text="Windows 启动时自动运行 MacWidget"
                                   FontSize="{DynamicResource FontSizeCaption}"
                                   Foreground="{DynamicResource SecondaryText}" />
                    </StackPanel>
                    <ToggleSwitch DockPanel.Dock="Right" VerticalAlignment="Center"
                                  IsChecked="False" />
                </DockPanel>
            </Border>

            <!-- 语言 -->
            <Border Background="{DynamicResource CardBackground}"
                    CornerRadius="{DynamicResource RadiusSm}"
                    Padding="20,14"
                    Margin="0,0,0,4">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Left" Spacing="{DynamicResource SpacingXs}"
                                VerticalAlignment="Center">
                        <TextBlock Text="语言" FontSize="{DynamicResource FontSizeSubtitle}"
                                   FontWeight="Medium" />
                        <TextBlock Text="设置应用界面语言"
                                   FontSize="{DynamicResource FontSizeCaption}"
                                   Foreground="{DynamicResource SecondaryText}" />
                    </StackPanel>
                    <Border DockPanel.Dock="Right" Background="{DynamicResource ValueChipBackground}"
                            CornerRadius="{DynamicResource RadiusXs}"
                            Padding="14,6"
                            VerticalAlignment="Center">
                        <TextBlock Text="简体中文" FontSize="{DynamicResource FontSizeBody}"
                                   Foreground="{DynamicResource SecondaryText}" />
                    </Border>
                </DockPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
