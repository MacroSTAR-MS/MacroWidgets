<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MacWidget.Views.Settings.Pages.NotificationSettingsPage">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,16,24,24"
                    Spacing="{DynamicResource SpacingSm}" MaxWidth="800">

            <TextBlock Text="通知" FontSize="28" FontWeight="Bold"
                       Foreground="{DynamicResource AccentBlue}"
                       Margin="0,0,0,8" />
            <TextBlock Text="管理提醒和通知方式" FontSize="{DynamicResource FontSizeBody}"
                       Foreground="{DynamicResource SecondaryText}"
                       Margin="0,0,0,24" />

            <!-- 启用通知 -->
            <Border Background="{DynamicResource CardBackground}"
                    CornerRadius="{DynamicResource RadiusSm}"
                    Padding="20,14"
                    Margin="0,0,0,4">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Left" Spacing="{DynamicResource SpacingXs}"
                                VerticalAlignment="Center">
                        <TextBlock Text="启用通知" FontSize="{DynamicResource FontSizeSubtitle}"
                                   FontWeight="Medium" />
                        <TextBlock Text="提醒事项到期时发送 Windows 通知"
                                   FontSize="{DynamicResource FontSizeCaption}"
                                   Foreground="{DynamicResource SecondaryText}" />
                    </StackPanel>
                    <ToggleSwitch DockPanel.Dock="Right" VerticalAlignment="Center"
                                  IsChecked="True" />
                </DockPanel>
            </Border>

            <!-- 提前提醒时间 -->
            <Border Background="{DynamicResource CardBackground}"
                    CornerRadius="{DynamicResource RadiusSm}"
                    Padding="20,14"
                    Margin="0,0,0,4">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Left" Spacing="{DynamicResource SpacingXs}"
                                VerticalAlignment="Center">
                        <TextBlock Text="提前提醒时间" FontSize="{DynamicResource FontSizeSubtitle}"
                                   FontWeight="Medium" />
                        <TextBlock Text="在事项到期前多久发送提醒"
                                   FontSize="{DynamicResource FontSizeCaption}"
                                   Foreground="{DynamicResource SecondaryText}" />
                    </StackPanel>
                    <Border DockPanel.Dock="Right" Background="{DynamicResource ValueChipBackground}"
                            CornerRadius="{DynamicResource RadiusXs}"
                            Padding="14,6"
                            VerticalAlignment="Center">
                        <TextBlock Text="15 分钟" FontSize="{DynamicResource FontSizeBody}"
                                   Foreground="{DynamicResource SecondaryText}" />
                    </Border>
                </DockPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
