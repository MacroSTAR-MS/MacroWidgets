<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MacWidget.Views.Settings.Pages.AppearanceSettingsPage">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,16,24,24"
                    Spacing="{DynamicResource SpacingSm}" MaxWidth="800">

            <TextBlock Text="外观" FontSize="28" FontWeight="Bold"
                       Foreground="{DynamicResource AccentBlue}"
                       Margin="0,0,0,8" />
            <TextBlock Text="自定义应用视觉样式" FontSize="{DynamicResource FontSizeBody}"
                       Foreground="{DynamicResource SecondaryText}"
                       Margin="0,0,0,24" />

            <!-- 主题 -->
            <Border Background="{DynamicResource CardBackground}"
                    CornerRadius="{DynamicResource RadiusSm}"
                    Padding="20,14"
                    Margin="0,0,0,4">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Left" Spacing="{DynamicResource SpacingXs}"
                                VerticalAlignment="Center">
                        <TextBlock Text="主题" FontSize="{DynamicResource FontSizeSubtitle}"
                                   FontWeight="Medium" />
                        <TextBlock Text="选择应用外观主题" FontSize="{DynamicResource FontSizeCaption}"
                                   Foreground="{DynamicResource SecondaryText}" />
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                Spacing="{DynamicResource SpacingSm}"
                                VerticalAlignment="Center">
                        <Border Background="{DynamicResource AccentBlue}"
                                CornerRadius="{DynamicResource RadiusXs}"
                                Padding="14,6"
                                Opacity="0.9">
                            <TextBlock Text="深色" FontSize="{DynamicResource FontSizeCaption}"
                                       Foreground="White" FontWeight="Medium" />
                        </Border>
                        <Border Background="{DynamicResource CardBackground}"
                                CornerRadius="{DynamicResource RadiusXs}"
                                Padding="14,6">
                            <TextBlock Text="浅色" FontSize="{DynamicResource FontSizeCaption}"
                                       Foreground="{DynamicResource SecondaryText}" />
                        </Border>
                        <Border Background="{DynamicResource CardBackground}"
                                CornerRadius="{DynamicResource RadiusXs}"
                                Padding="14,6">
                            <TextBlock Text="跟随系统" FontSize="{DynamicResource FontSizeCaption}"
                                       Foreground="{DynamicResource SecondaryText}" />
                        </Border>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- 组件透明度 -->
            <Border Background="{DynamicResource CardBackground}"
                    CornerRadius="{DynamicResource RadiusSm}"
                    Padding="20,14"
                    Margin="0,0,0,4">
                <StackPanel Spacing="{DynamicResource SpacingSm}">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left" Spacing="{DynamicResource SpacingXs}"
                                    VerticalAlignment="Center">
                            <TextBlock Text="小组件透明度" FontSize="{DynamicResource FontSizeSubtitle}"
                                       FontWeight="Medium" />
                            <TextBlock Text="调整小组件背景的不透明度"
                                       FontSize="{DynamicResource FontSizeCaption}"
                                       Foreground="{DynamicResource SecondaryText}" />
                        </StackPanel>
                        <TextBlock DockPanel.Dock="Right" Text="80%"
                                   FontSize="{DynamicResource FontSizeBody}"
                                   Foreground="{DynamicResource SecondaryText}"
                                   VerticalAlignment="Center" />
                    </DockPanel>
                    <Slider Minimum="0" Maximum="100" Value="80"
                            Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <!-- 圆角大小 -->
            <Border Background="{DynamicResource CardBackground}"
                    CornerRadius="{DynamicResource RadiusSm}"
                    Padding="20,14"
                    Margin="0,0,0,4">
                <StackPanel Spacing="{DynamicResource SpacingSm}">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left" Spacing="{DynamicResource SpacingXs}"
                                    VerticalAlignment="Center">
                            <TextBlock Text="圆角大小" FontSize="{DynamicResource FontSizeSubtitle}"
                                       FontWeight="Medium" />
                            <TextBlock Text="调整小组件的圆角半径"
                                       FontSize="{DynamicResource FontSizeCaption}"
                                       Foreground="{DynamicResource SecondaryText}" />
                        </StackPanel>
                        <TextBlock DockPanel.Dock="Right" Text="12px"
                                   FontSize="{DynamicResource FontSizeBody}"
                                   Foreground="{DynamicResource SecondaryText}"
                                   VerticalAlignment="Center" />
                    </DockPanel>
                    <Slider Minimum="0" Maximum="24" Value="12"
                            Margin="0,4,0,0" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
